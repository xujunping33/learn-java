# 复制为同目录 db.properties 后按需修改（db.properties 可不入库，见 README）
#
# Ubuntu 常见：mysql 里 root 使用 auth_socket，JDBC 用 root+密码会报 Access denied。
# 解决：在 MySQL 中建专用账号（示例）：
#   CREATE USER IF NOT EXISTS 'oa_demo'@'localhost' IDENTIFIED BY '你的强密码';
#   GRANT ALL PRIVILEGES ON oa_demo.* TO 'oa_demo'@'localhost';
#   FLUSH PRIVILEGES;
# 然后把下面 db.user/db.password 改成 oa_demo / 你的强密码。
db.url=jdbc:mysql://127.0.0.1:3306/oa_demo?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai&characterEncoding=utf8
db.user=oa_demo
db.password=你的密码
