# 复制本文件为 `.env` 后按需修改（仓库根 `.gitignore` 会忽略 `.env`）
# Day192：Compose 默认变量收口

# ---- MySQL（须与 deploy/mysql/init.sql 中库名一致，默认 ssm_social）----
MYSQL_DATABASE=ssm_social
DB_USER=admin
DB_PASSWORD=AdminPass_123!
MYSQL_ROOT_PASSWORD=rootpass

# 应用 JDBC（一般不必改 host；改库名时须与 MYSQL_DATABASE、init.sql 对齐）
# DB_URL=jdbc:mysql://mysql:3306/ssm_social?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai&characterEncoding=utf8

# ---- Redis（Compose 内网服务名，一般保持默认）----
REDIS_HOST=redis
REDIS_PORT=6379

# ---- 宿主机端口 ----
APP_PORT=8081
NGINX_HTTP_PORT=80

# ---- RabbitMQ（带 management UI）----
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=adminpass
RABBITMQ_AMQP_PORT=5672
RABBITMQ_HTTP_PORT=15672

# ---- MinIO（W31：对象存储，S3 compatible）----
# API: http://127.0.0.1:${MINIO_API_PORT}  Console: http://127.0.0.1:${MINIO_CONSOLE_PORT}
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=boot-social

# ---- 应用容器内 S3 客户端（与 MinIO root 账号一致即可；勿提交到仓库）----
# compose 已把 MINIO_ACCESS_KEY/SECRET 传给 app；本地 spring-boot:run 时可自行 export。
# MINIO_ENDPOINT=http://minio:9000
# 让 presigned URL 在宿主机可直接访问（别用 http://minio:9000）
# MINIO_PUBLIC_ENDPOINT=http://127.0.0.1:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
